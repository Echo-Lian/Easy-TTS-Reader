{
  "name": "easy-tts-reader",
  "version": "1.0.0",
  "description": "Free AI-powered Text-to-Speech reader with Ollama",
  "main": "desktop/main.js",
  "scripts": {
    "start:desktop": "electron desktop/main.js",
    "build:chrome": "node scripts/build-chrome.js",
    "build:zotero": "node scripts/build-zotero.js",
    "build:desktop": "electron-builder",
    "build:all": "npm run build:chrome && npm run build:zotero && npm run build:desktop"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "ollama",
    "chrome-extension",
    "zotero",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "archiver": "^6.0.0",
    "canvas": "^3.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "fs-extra": "^11.0.0"
  },
  "build": {
    "appId": "com.easyttsreader.app",
    "productName": "Easy TTS Reader",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "desktop/**/*",
      "shared/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
